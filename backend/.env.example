# Django
DJANGO_SECRET_KEY=change-this-to-a-secure-random-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# Ollama (local LLM)
OLLAMA_BASE_URL=http://localhost:11434

# Groq API (for cloud deployment - free tier, no credit card required)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Embedding Model (upgraded to bge-large-en-v1.5 for better retrieval)
EMBEDDING_MODEL_NAME=BAAI/bge-large-en-v1.5

# Default LLM
DEFAULT_LLM_PROVIDER=ollama
DEFAULT_OLLAMA_MODEL=phi4:mini

# ChromaDB + BM25 Hybrid Search
CHROMA_DB_PATH=./chroma_db
